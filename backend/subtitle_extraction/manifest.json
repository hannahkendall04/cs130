{
  "manifest_version": 3,
  "name": "flixtra",
  "version": "1.0",
  "description": "Automatically extracts and downloads Netflix subtitles with show titles.",
  "permissions": [
    "webRequest",
    "storage",
    "downloads"
  ],
  "host_permissions": [
    "https://*.netflix.com/*",
    "https://*.nflxvideo.net/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.netflix.com/*"],
      "js": ["content.js"]
    }
  ]
}