{
  "manifest_version": 3,
  "name": "Flixtra",
  "version": "1.0",
  "description": "A Chrome extension that provides extra features to Netflix.",
  "permissions": ["activeTab", "storage", "webRequest", "downloads"],
  "host_permissions": [
    "https://*.netflix.com/*",
    "https://*.nflxvideo.net/*",
    "http://127.0.0.1:8000/*"
  ],
  "action": {
    "default_popup": "index.html"
  },
  "content_scripts": [
    {
      "matches": ["https://*.netflix.com/*"],
      "js": ["skipRange.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.netflix.com/*"],
      "js": ["netflixSeek.js"],
      "run_at": "document_idle",
      "world": "MAIN"
    },
    {
      "matches": ["https://www.netflix.com/*"],
      "js": ["subtitles.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.netflix.com/*"],
      "js": ["comments.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["iframe.html", "iframe.js", "main.css"],
      "matches": ["https://www.netflix.com/*"]
    }
  ],
  "background": {
    "service_worker": "background.js"
  }
}
