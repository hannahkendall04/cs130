{
  "manifest_version": 3,
  "name": "Flixtra",
  "version": "1.0",
  "description": "A Chrome extension that provides extra features to Netflix.",
  "permissions": [
    "activeTab", 
    "storage",
    "webRequest",
    "downloads"
  ],
  "host_permissions": [
    "https://*.netflix.com/*",
    "https://*.nflxvideo.net/*"
  ],
  "action": {
    "default_popup": "index.html"
  },
  "content_scripts": [
    {
      "matches": ["https://*.netflix.com/*"],
      "js": ["skipRange.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.netflix.com/*"],
      "js": ["netflixSeek.js"],
      "run_at": "document_idle",
      "world": "MAIN"
    },
    {
      "matches": ["https://www.netflix.com/*"],
      "js": ["subtitles.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  }
}

