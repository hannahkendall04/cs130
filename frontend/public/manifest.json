{
  "manifest_version": 3,
  "name": "flixtra",
  "version": "1.0.0",
  "description": "Providing extra features to Netflix",
  "action": {
    "default_popup": "index.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["tabs", "scripting"],
  "host_permissions": ["*://*.youtube.com/*"],
  "content_scripts": [
    {
      "matches": ["*://*.youtube.com/*"],
      "js": ["contentScript.js", "skipRange.js"]
    }
  ]
}
